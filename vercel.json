{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://fast-api-mock.netlify.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
