{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 100,
  "sortImports": true,
  "sortTailwindcss": {
    "stylesheet": "./app/styles/index.css",
    "functions": ["cn", "cva"]
  },
  "ignorePatterns": ["app/services/**", "app/components/ui/**"]
}
